{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/scripts.js", "dest": "/public/scripts.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}